#!/bin/bash


if [[ $# -eq 0 ]]
then
    echo "This script requires at least an argument"
    echo "Use : "
    echo -e "\tdev_toolbox help"
    echo "to have more details"
else

if [[ $1 == "help" ]]
then

    echo ""
    echo -e "\t++------------------------------++"
    echo -e "\t||   Welcome to dev_toolbox !   ||"
    echo -e "\t++------------------------------++"
    echo ""
    echo "dev_toolbox is a basch script containing some useful automation to ease the developement"
    echo ""
    echo "It contains the following tools :"
    echo -e "\tdev_toolbox version : a tool to set or increment uniformely the version number accross all the project's files"
    echo ""
    echo "In depth explanation :"
    echo "VERSION :"
    echo -e "\tShow :"
    echo -e "\t\t- dev_toolbox version : Show the list of files that are candidates for versions updates"
    echo ""
    echo -e "\tIncrements :"
    echo -e "\t\t- dev_toolbox version bug : Incrementing the last digit by one"
    echo -e "\t\t- dev_toolbox version minor : Incrementing the middle digit by one and reseting the last digit to 0"
    echo -e "\t\t- dev_toolbox version major : Incrementing the first digit by one and reseting the other 2 digits to 0"
    echo ""
    echo -e "\tReset :"
    echo -e "\t\t- dev_toolbox version reset : Reset the version number back to 1.0.0"
    echo ""
    echo -e "\tSet :"
    echo -e "\t\t- dev_toolbox version [version number] : Set the version number to [version number]"
    echo -e "\t\t- dev_toolbox version set [version number] : Set the version number to [version number]"
    echo -e "\t\t[version number] is of the form : [0-9]+\.[0-9]+\.[0-9]+"
    echo -e "\t\tExemple : 2.1.13"
    echo ""

elif [[ $1 == "version" ]]
then
    if [[ $# -eq 1 ]]
    then

    grep -Irl -E "Version : [0-9]+\.[0-9]+\.[0-9]+" *

    elif [[ $# -eq 2 ]]
    then

    if [[ $2 == "bug" ]]
    then
        # Incrementing the last digit by one

        grep -Irl -E "Version : [0-9]+\.[0-9]+\.[0-9]+" * | while read line
        do
            sed -i -E 's/(.*Version : [0-9]+\.[0-9]+\.)([0-9])+/echo "\1$((\2+1))"/e' $line
        done
    elif [[ $2 == "minor" ]]
    then
        # Incrementing the middle digit by one and reseting the last digit to 0
        
        grep -Irl -E "Version : [0-9]+\.[0-9]+\.[0-9]+" * | while read line
        do
            sed -i -E 's/(.*Version : [0-9]+\.)([0-9]+)\.[0-9]+/echo "\1$((\2+1)).0"/e' $line
        done
    elif [[ $2 == "major" ]]
    then
        # Incrementing the first digit by one and reseting the other 2 digits to 0
        
        grep -Irl -E "Version : [0-9]+\.[0-9]+\.[0-9]+" * | while read line
        do
            sed -i -E 's/(.*Version : )([0-9])+\.[0-9]+\.[0-9]+/echo "\1$((\2+1)).0.0"/e' $line
        done
    elif [[ $2 == "reset" ]]
    then
        # Reset the version number back to 1.0.0

        grep -Irl -E "Version : [0-9]+\.[0-9]+\.[0-9]+" * | while read line
        do
            sed -i -E s"/(Version : )[0-9]+.[0-9]+.[0-9]+/\11.0.0/" $line
        done
    elif [[ $2 =~ [0-9]+\.[0-9]+\.[0-9]+ ]]
    then
        # Same as the set option

        grep -Irl -E "Version : [0-9]+\.[0-9]+\.[0-9]+" * | while read line
        do
            sed -i -E "s/Version : [0-9]+\.[0-9]+\.[0-9]+/Version : $2/" $line
        done
    else
        echo "This isn't a valid option"
        echo "Use : "
        echo -e "\tdev_toolbox help"
        echo "to have more details"
    fi

    elif [[ $# -eq 3 ]]
    then

    if [[ $2 == "set" ]] && [[ $3 =~ [0-9]+\.[0-9]+\.[0-9]+ ]]
    then
        # The user specify a new version number
        
        grep -Irl -E "Version : [0-9]+\.[0-9]+\.[0-9]+" * | while read line
        do
            sed -i -E "s/Version : [0-9]+\.[0-9]+\.[0-9]+/Version : $3/" $line
        done
    else
        echo "This isn't a valid option"
        echo "Use : "
        echo -e "\tdev_toolbox help"
        echo "to have more details"
    fi

    fi
else
    echo "This isn't a valid option"
    echo "Use : "
    echo -e "\tdev_toolbox help"
    echo "to have more details"
fi

fi
